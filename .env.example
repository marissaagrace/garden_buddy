# Vite only exposes variables prefixed with VITE_ (not NEXT_PUBLIC_).
# From Supabase → Settings → API: Project URL + anon JWT or publishable client key.

VITE_SUPABASE_URL=https://your-project.supabase.co

# Use one of the following (JWT anon or new publishable key):
# VITE_SUPABASE_ANON_KEY=eyJ...
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Optional: set on Vercel so email confirmation links use your deploy URL, not localhost.
# VITE_SITE_URL=https://your-app.vercel.app
#
# To sign up without email confirmation (recommended for personal use):
# Supabase Dashboard → Authentication → Sign In / Providers → Email →
# turn OFF "Confirm email" (or disable "Enable email confirmations").
# Also set Authentication → URL Configuration → Site URL to your production URL.
